# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/aiworkout

# Google Gemini API key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Session secret – used to sign HTTP-only session cookies
# Generate a strong random value, e.g.: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-secret-value
# Google Analytics 4 Measurement ID
# Get yours at: https://analytics.google.com/
# Leave empty to disable Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console site verification token
# Get yours at: https://search.google.com/search-console/
# Leave empty to disable Search Console verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google AdSense client ID
# Get yours at: https://www.google.com/adsense/
# Leave empty to disable Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
